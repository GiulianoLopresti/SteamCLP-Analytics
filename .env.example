# Copia este archivo como .env (sin el .example) y ajusta los valores
# si necesitas algo distinto a los defaults. El archivo .env real NO se
# sube al repositorio (esta en .gitignore), solo esta plantilla.

# Ruta al CSV del catalogo de Steam descargado de Kaggle
CSV_PATH=data/SteamGames.csv

# Ruta a la base de datos propia del proyecto
DB_PATH=data/steamclp.db

# URL de la API de tipo de cambio (USD -> todas las monedas, incluye CLP)
EXCHANGE_API_URL=https://open.er-api.com/v6/latest/USD

# Reintentos y espera (segundos) si la API de tipo de cambio falla
API_REINTENTOS=3
API_ESPERA_SEGUNDOS=2

# Puerto en el que corre el dashboard
DASHBOARD_PORT=8050
